<%- include('partials/header') %>

<div class="form-page">
  <div style="position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?w=1920&q=80') center/cover;opacity:0.08;"></div>
  <div class="form-container">
    <div style="text-align:center; margin-bottom:8px;">
      <div style="font-family:'Playfair Display',serif; font-size:14px; letter-spacing:4px; color:var(--gold);">★ ★ ★ ★ ★</div>
    </div>
    <h1 class="form-title" style="text-align:center;">Welcome <em>Back</em></h1>
    <p class="form-sub" style="text-align:center;">Sign in to access your exclusive Icon5Star account</p>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="your@email.com" required>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
      </div>
      <button type="submit" class="form-submit">Sign In to Icon5Star</button>
    </form>

    <div style="text-align:center; margin-top:30px;">
      <div style="display:flex; align-items:center; gap:16px; margin-bottom:24px;">
        <div style="flex:1; height:1px; background:var(--border);"></div>
        <span style="font-size:11px; color:var(--text-muted); letter-spacing:2px;">OR</span>
        <div style="flex:1; height:1px; background:var(--border);"></div>
      </div>
      <p class="form-link">New to Icon5Star? <a href="/auth/signup">Create Account</a></p>
      <p style="margin-top:12px; font-size:12px; color:var(--text-muted);">
        <a href="/" style="color:var(--text-muted);">← Back to Home</a>
      </p>
    </div>

    <div style="margin-top:40px; padding:20px; border:1px solid var(--border); text-align:center;">
      <div style="font-size:10px; letter-spacing:2px; color:var(--gold); margin-bottom:8px; text-transform:uppercase;">Member Benefits</div>
      <div style="display:flex; justify-content:space-around;">
        <div style="font-size:12px; color:var(--text-muted);">🎁 Exclusive Offers</div>
        <div style="font-size:12px; color:var(--text-muted);">⚡ Fast Checkout</div>
        <div style="font-size:12px; color:var(--text-muted);">📋 Booking History</div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
