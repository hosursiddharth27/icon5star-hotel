<%- include('partials/header') %>

<div class="profile-page">
  <div class="profile-header">
    <div class="profile-avatar"><%= user.name[0].toUpperCase() %></div>
    <div>
      <h1 class="profile-name"><%= user.name %></h1>
      <p class="profile-email"><%= user.email %></p>
      <p style="font-size:11px; letter-spacing:2px; color:var(--gold); text-transform:uppercase; margin-top:6px;">
        <% if (user.role === 'admin') { %>👑 Admin Account<% } else { %>⭐ Elite Member<% } %>
      </p>
    </div>
    <div style="margin-left:auto; display:flex; gap:16px; flex-wrap:wrap;">
      <a href="/booking/room" class="btn-primary" style="text-decoration:none;">+ Book Room</a>
      <a href="/booking/table" class="btn-secondary" style="text-decoration:none;">+ Book Table</a>
    </div>
  </div>

  <!-- Stats -->
  <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-bottom:50px;">
    <div style="background:var(--dark2); border:1px solid var(--border); padding:24px; border-left:3px solid var(--gold);">
      <div style="font-family:'Playfair Display',serif; font-size:36px; color:var(--gold);"><%= roomBookings.length %></div>
      <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--text-muted);">Room Bookings</div>
    </div>
    <div style="background:var(--dark2); border:1px solid var(--border); padding:24px; border-left:3px solid var(--gold);">
      <div style="font-family:'Playfair Display',serif; font-size:36px; color:var(--gold);"><%= tableBookings.length %></div>
      <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--text-muted);">Table Bookings</div>
    </div>
    <div style="background:var(--dark2); border:1px solid var(--border); padding:24px; border-left:3px solid var(--gold);">
      <div style="font-family:'Playfair Display',serif; font-size:36px; color:var(--gold);">
        <%= roomBookings.filter(b => b.status === 'confirmed').length + tableBookings.filter(b => b.status === 'confirmed').length %>
      </div>
      <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--text-muted);">Active Bookings</div>
    </div>
    <div style="background:var(--dark2); border:1px solid var(--border); padding:24px; border-left:3px solid var(--gold);">
      <div style="font-family:'Playfair Display',serif; font-size:36px; color:var(--gold);">
        ₹<%= ([...roomBookings, ...tableBookings].filter(b => b.status !== 'cancelled').reduce((s, b) => s + (b.totalPrice || 0), 0)).toLocaleString('en-IN') %>
      </div>
      <div style="font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--text-muted);">Total Spent</div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="booking-tabs">
    <button class="tab-btn active" data-tab="room-tab">🛏️ &nbsp; Room Bookings (<%= roomBookings.length %>)</button>
    <button class="tab-btn" data-tab="table-tab">🍽️ &nbsp; Table Bookings (<%= tableBookings.length %>)</button>
  </div>

  <!-- Room Bookings Tab -->
  <div class="tab-content active" id="room-tab">
    <% if (roomBookings.length === 0) { %>
      <div class="empty-state">
        <span class="empty-state-icon">🛏️</span>
        <div class="empty-state-text">No room bookings yet</div>
        <p style="color:var(--text-muted); font-size:14px; margin-bottom:30px;">Discover our luxurious rooms and suites</p>
        <a href="/booking/room" class="btn-primary" style="text-decoration:none;">Book a Room Now</a>
      </div>
    <% } else { %>
      <% roomBookings.forEach(booking => { %>
        <div class="booking-card">
          <div>
            <div class="booking-id">Booking ID: <%= booking.bookingId %></div>
            <span class="badge badge-<%= booking.status %>"><%= booking.status.toUpperCase() %></span>
            <div class="booking-title"><%= booking.roomType %></div>
            <div class="booking-meta">
              <div class="booking-meta-item">
                <strong>🗓️ Check-in</strong>
                <%= new Date(booking.checkIn).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'}) %>
              </div>
              <div class="booking-meta-item">
                <strong>🗓️ Check-out</strong>
                <%= new Date(booking.checkOut).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'}) %>
              </div>
              <div class="booking-meta-item">
                <strong>🚪 Room</strong>
                #<%= booking.roomNumber %>
              </div>
              <div class="booking-meta-item">
                <strong>👥 Guests</strong>
                <%= booking.guests %>
              </div>
              <div class="booking-meta-item">
                <strong>📅 Booked On</strong>
                <%= new Date(booking.createdAt).toLocaleDateString('en-IN') %>
              </div>
            </div>
            <% if (booking.specialRequests) { %>
              <p style="font-size:12px; color:var(--text-muted); margin-top:12px;">📝 <em><%= booking.specialRequests %></em></p>
            <% } %>
            <% if (booking.status === 'confirmed') { %>
              <form action="/booking/room/cancel/<%= booking._id %>" method="POST" class="cancel-form" style="display:inline;">
                <button type="submit" class="btn-cancel">✕ Cancel Booking</button>
              </form>
            <% } %>
          </div>
          <div style="text-align:right;">
            <div class="booking-price">
              ₹<%= booking.totalPrice?.toLocaleString('en-IN') %>
              <small>₹<%= booking.pricePerNight?.toLocaleString('en-IN') %>/night</small>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- Table Bookings Tab -->
  <div class="tab-content" id="table-tab">
    <% if (tableBookings.length === 0) { %>
      <div class="empty-state">
        <span class="empty-state-icon">🍽️</span>
        <div class="empty-state-text">No table bookings yet</div>
        <p style="color:var(--text-muted); font-size:14px; margin-bottom:30px;">Experience our world-class dining</p>
        <a href="/booking/table" class="btn-primary" style="text-decoration:none;">Reserve a Table</a>
      </div>
    <% } else { %>
      <% tableBookings.forEach(booking => { %>
        <div class="booking-card">
          <div>
            <div class="booking-id">Booking ID: <%= booking.bookingId %></div>
            <span class="badge badge-<%= booking.status %>"><%= booking.status.toUpperCase() %></span>
            <div class="booking-title"><%= booking.tableType %></div>
            <div class="booking-meta">
              <div class="booking-meta-item">
                <strong>🗓️ Date</strong>
                <%= new Date(booking.date).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'}) %>
              </div>
              <div class="booking-meta-item">
                <strong>⏰ Time</strong>
                <%= booking.time %>
              </div>
              <div class="booking-meta-item">
                <strong>👥 Guests</strong>
                <%= booking.guests %>
              </div>
              <% if (booking.occasion) { %>
              <div class="booking-meta-item">
                <strong>🎉 Occasion</strong>
                <%= booking.occasion %>
              </div>
              <% } %>
              <div class="booking-meta-item">
                <strong>🍛 Preference</strong>
                <%= booking.foodPreference || 'Any' %>
              </div>
            </div>
            <% if (booking.specialRequests) { %>
              <p style="font-size:12px; color:var(--text-muted); margin-top:12px;">📝 <em><%= booking.specialRequests %></em></p>
            <% } %>
            <% if (booking.status === 'confirmed') { %>
              <form action="/booking/table/cancel/<%= booking._id %>" method="POST" class="cancel-form" style="display:inline;">
                <button type="submit" class="btn-cancel">✕ Cancel Booking</button>
              </form>
            <% } %>
          </div>
          <div style="text-align:right;">
            <div class="booking-price">
              ₹<%= booking.totalPrice?.toLocaleString('en-IN') %>
              <small>Table reservation fee</small>
            </div>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <% if (user.role === 'admin') { %>
    <div style="margin-top:50px; padding:24px; border:1px solid var(--gold); text-align:center;">
      <div style="font-size:10px; letter-spacing:3px; color:var(--gold); margin-bottom:12px; text-transform:uppercase;">Admin Access</div>
      <a href="/admin/dashboard" class="btn-primary" style="text-decoration:none;">Go to Admin Dashboard →</a>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
